{
  "name": "menuwebar",
  "version": "0.0.0",
  "private": true,
  "description": "A React + Express digital restaurant menu for featuring Augmented Reality food visualization. Customers can browse the menu, preview dishes in 3D, and project them onto their table using AR.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start:client": "npm run start --workspace=client",
    "start:server": "npm run start --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "npm run build --workspace=client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "@eslint/js": "^9.39.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.2"
  }
}
